# ZeroPass — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env to source control.

# Your deployer wallet private key (WITHOUT the 0x prefix)
PRIVATE_KEY=your_private_key_here

# Polygon Amoy RPC (default public endpoint works fine for testing)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Optional: Polygonscan API key for contract verification
# Get one at https://amoy.polygonscan.com/myapikey
POLYGONSCAN_API_KEY=
